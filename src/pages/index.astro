---
import Layout from "@/layouts/main.astro"
import { Navbar } from "@/components/Navbar"
import { Button } from "@/components/ui/button"
import {
  faqItems,
  getHomepageStructuredData,
  siteConfig,
} from "@/lib/site"

const structuredData = getHomepageStructuredData(
  Astro.site ?? new URL(siteConfig.siteUrl),
)
---

<Layout
  title={siteConfig.defaultTitle}
  description={siteConfig.defaultDescription}
  keywords={siteConfig.defaultKeywords}
  structuredData={structuredData}
>
  <Navbar client:load />
  
  <main class="relative">
    {/* Tall Hero Section with Breathing Room */}
    <section class="relative pt-36 md:pt-48 pb-24 z-10">
      <div class="mx-auto flex flex-col items-center px-4 sm:px-6 lg:px-8 text-center max-w-7xl">
        
        {/* Eyebrow Label */}
        <div class="inline-flex items-center rounded-full border border-primary/20 bg-primary/10 px-3 py-1 text-sm font-medium text-primary mb-8 transition-colors hover:bg-primary/20">
          <span class="flex h-2 w-2 rounded-full bg-primary mr-2 animate-pulse"></span>
          Meet WidgetAI 1.0
        </div>
        
        {/* Large Bold Headline */}
        <h1 class="max-w-4xl text-5xl font-extrabold tracking-tight sm:text-6xl lg:text-7xl mb-6 text-foreground text-balance">
          AI website widgets <br class="hidden sm:block" /> made simple.
        </h1>
        
        {/* Short Supporting Paragraph */}
        <p class="max-w-2xl text-lg sm:text-xl text-muted-foreground mb-10 text-balance leading-relaxed">
          Control what your assistant knows, how it looks, and where it lives. Install your custom AI with a single script tag and let it handle your customer interactions effortlessly.
        </p>
        
        {/* Two CTA Buttons */}
        <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto mb-16 md:mb-24">
          <a href={siteConfig.dashboardUrl} class="w-full sm:w-auto">
            <Button client:load size="lg" className="rounded-full h-12 px-8 text-base shadow-lg hover:shadow-xl transition-shadow w-full">
              Start Building Your Widget
            </Button>
          </a>
          <a href="#how-it-works" class="w-full sm:w-auto">
            <Button client:load size="lg" variant="outline" className="w-full rounded-full h-12 px-8 text-base border-border/50 bg-background hover:bg-muted/50 transition-colors">
              How it works
            </Button>
          </a>
        </div>
        
        {/* Large Dashboard Preview Anchored at the Bottom */}
        {/* Negative bottom margin forces it to slightly overlap the next section */}
        <div class="relative w-full max-w-5xl mx-auto -mb-24 sm:-mb-48 lg:-mb-64 z-20 dashboard-preview-container" style="perspective: 1000px;">
          <div id="dashboard-preview" class="relative w-full h-full transition-transform duration-75 ease-out" style="transform: rotateX(15deg) translateY(40px) scale(0.95); opacity: 0;">
            {/* Subtle glow effect behind the dashboard */}
            <div class="absolute -inset-1 sm:-inset-4 bg-primary/30 rounded-2xl sm:rounded-[2.5rem] blur-xl sm:blur-2xl opacity-40 -z-10"></div>
            
            <div class="rounded-xl sm:rounded-2xl border border-primary/40 bg-background/50 p-1 sm:p-2 shadow-[0_0_50px_-12px_rgba(0,0,0,0.3)] backdrop-blur-sm">
              {/* Desktop Preview */}
              <img 
                src="/preview.png" 
                alt="WidgetAI Dashboard Preview" 
                width="2766"
                height="1388"
                class="hidden sm:block w-full h-auto rounded-lg sm:rounded-xl border border-primary/20 shadow-inner object-cover"
              />
              {/* Mobile Preview */}
              <img 
                src="/preview-mobile.png" 
                alt="WidgetAI Mobile Dashboard Preview" 
                width="572"
                height="1228"
                class="block sm:hidden w-full h-auto rounded-xl border border-primary/20 shadow-inner object-cover"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* How It Works Section */}
    <section id="how-it-works" class="relative pt-36 pb-24 sm:pt-64 sm:pb-32 bg-secondary/5 z-0">
      <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
        <div class="text-center max-w-3xl mx-auto mb-16 sm:mb-24">
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl mb-4 text-foreground">
            How it works
          </h2>
          <p class="text-lg text-muted-foreground">
            Get your AI assistant up and running in minutes. No coding required, just answer a few questions and paste a script.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12 w-full max-w-5xl mx-auto">
          {/* Step 1 */}
          <div class="flex flex-col items-center sm:items-start text-center sm:text-left relative group">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 border border-primary/20 text-primary font-bold text-xl mb-6 shadow-sm">
              1
            </div>
            <h3 class="text-xl font-semibold mb-3 text-foreground">Create a widget</h3>
            <p class="text-muted-foreground leading-relaxed">
              Sign up and create your first AI widget. Give it a name and customize its appearance to match your brand's colors and style.
            </p>
          </div>

          {/* Step 2 */}
          <div class="flex flex-col items-center sm:items-start text-center sm:text-left relative group">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 border border-primary/20 text-primary font-bold text-xl mb-6 shadow-sm">
              2
            </div>
            <h3 class="text-xl font-semibold mb-3 text-foreground">Add context</h3>
            <p class="text-muted-foreground leading-relaxed">
              Provide your business context and custom instructions. Tell the AI what to answer, how to behave, and what features to highlight.
            </p>
          </div>

          {/* Step 3 */}
          <div class="flex flex-col items-center sm:items-start text-center sm:text-left relative group">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 border border-primary/20 text-primary font-bold text-xl mb-6 shadow-sm">
              3
            </div>
            <h3 class="text-xl font-semibold mb-3 text-foreground">Embed easily</h3>
            <p class="text-muted-foreground leading-relaxed">
              Copy the generated code snippet and add it to your website. The widget immediately appears and starts working for your visitors.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* Features Grid Section */}
    <section id="features" class="relative py-24 sm:py-32 bg-background z-10">
      <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
        <div class="text-center max-w-3xl mx-auto mb-16 sm:mb-20">
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl mb-4 text-foreground">
            Everything you need
          </h2>
          <p class="text-lg text-muted-foreground">
            Powerful capabilities wrapped in an elegant, minimal interface. Built to give you full control over your AI assistant.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8 auto-rows-[minmax(180px,auto)]">
          {/* Card 1: Embeddable chat widget (Large square, spans 2x2) */}
          <div class="group relative rounded-3xl border border-border/50 bg-background lg:bg-gradient-to-br from-background to-secondary/5 p-8 sm:p-10 shadow-sm transition-all hover:shadow-md hover:border-primary/20 md:col-span-2 lg:col-span-2 lg:row-span-2 flex flex-col md:flex-row items-center gap-8 overflow-hidden">
            
            {/* Text Content Left */}
            <div class="z-10 md:w-1/2 flex flex-col justify-center">
              <div class="mb-5 inline-flex shrink-0 h-14 w-14 items-center justify-center rounded-2xl bg-primary/10 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"/></svg>
              </div>
              <h3 class="mb-3 text-2xl font-bold text-foreground tracking-tight">Embeddable Widget</h3>
              <p class="text-sm text-muted-foreground leading-relaxed">
                A beautifully designed chat interface that lives natively in the bottom corner of your website, perfectly adapting to your visitors.
              </p>
            </div>

            {/* Widget Preview Image Right */}
            <div class="md:w-1/2 w-full flex justify-center items-center group-hover:scale-[1.03] transition-transform duration-500 ease-out">
              <img 
                src="/widget-preview.png" 
                alt="Widget Preview" 
                width="638"
                height="1158"
                loading="lazy"
                class="w-full max-w-[320px] h-auto object-contain drop-shadow-2xl rounded-2xl" 
              />
            </div>
          </div>

          {/* Card 2: Simple installation (Wide rectangle, spans 2 cols) */}
          <div class="group relative rounded-3xl border border-border/50 bg-background py-6 px-4 lg:py-8 lg:px-5 shadow-sm transition-all hover:shadow-md hover:border-primary/20 md:col-span-1 lg:col-span-2 flex flex-col justify-center">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary mx-2 lg:mx-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>
            </div>
            <h3 class="mb-2 text-xl font-semibold text-foreground tracking-tight mx-2 lg:mx-3">1-Minute Install</h3>
            <p class="text-sm text-muted-foreground leading-relaxed max-w-md mb-6 mx-2 lg:mx-3">
              Just copy a single lightweight script tag into your website. Works independent of your tech stack.
            </p>
            {/* The Script Wrapper */}
            <div class="w-full mt-auto overflow-hidden">
              <div class="font-mono text-xs sm:text-sm md:text-base leading-relaxed bg-[#1e1e1e] py-3 px-2 sm:px-3 rounded-xl border border-border/50 shadow-inner w-full whitespace-pre-wrap break-all flex flex-col">
                <div>
                  <span class="text-gray-400">&lt;</span><span class="text-[#569cd6]">script</span>
                </div>
                <div class="pl-2">
                  <span class="text-[#9cdcfe]">src</span><span class="text-gray-400">=</span><span class="text-[#ce9178]">{`"${siteConfig.embedScriptUrl}"`}</span>
                </div>
                <div class="pl-2">
                  <span class="text-[#9cdcfe]">data-widget-id</span><span class="text-gray-400">=</span><span class="text-[#ce9178]">"..."</span><span class="text-gray-400">&gt;</span>
                </div>
                <div>
                  <span class="text-gray-400">&lt;/</span><span class="text-[#569cd6]">script</span><span class="text-gray-400">&gt;</span>
                </div>
              </div>
            </div>
          </div>

          {/* Card 3: Widget customization (Small square, 11) */}
          <div class="group relative rounded-3xl border border-border/50 bg-background p-6 shadow-sm transition-all hover:shadow-md hover:border-primary/20 md:col-span-1 lg:col-span-1 flex flex-col justify-end">
            <div class="mb-auto inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold text-foreground tracking-tight">Custom Style</h3>
            <p class="text-sm text-muted-foreground leading-relaxed line-clamp-2">
              Tweak colors and panel themes to match your brand completely.
            </p>
          </div>

          {/* Card 4: Domain restrictions (Small square, 11) */}
          <div class="group relative rounded-3xl border border-border/50 bg-background p-6 shadow-sm transition-all hover:shadow-md hover:border-primary/20 md:col-span-1 lg:col-span-1 flex flex-col justify-end">
            <div class="mb-auto inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold text-foreground tracking-tight">Domain Auth</h3>
            <p class="text-sm text-muted-foreground leading-relaxed line-clamp-2">
              Secure your widget by allowing it to load only on approved sites.
            </p>
          </div>

          {/* Card 5: AI configuration (Wide rectangle, spans 2 cols) */}
          <div class="group relative rounded-3xl border border-border/50 bg-background p-6 lg:p-8 shadow-sm transition-all hover:shadow-md hover:border-primary/20 md:col-span-2 lg:col-span-2 flex flex-col sm:flex-row sm:items-center gap-6">
            <div class="inline-flex shrink-0 h-14 w-14 items-center justify-center rounded-2xl bg-primary/10 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            </div>
            <div>
              <h3 class="mb-2 text-xl font-semibold text-foreground tracking-tight">AI Configuration</h3>
              <p class="text-sm text-muted-foreground leading-relaxed">
                Use our built-in models out of the box, or securely plug in your own API credentials to run specific customized models.
              </p>
            </div>
          </div>

          {/* Card 6: Context-based answers (Wide rectangle, spans 2 cols on lg) */}
          <div class="group relative rounded-3xl border border-border/50 bg-background p-6 lg:p-8 shadow-sm transition-all hover:shadow-md hover:border-primary/20 md:col-span-2 lg:col-span-2 flex flex-col justify-center">
            <div class="flex items-center gap-6 mb-5">
              <div class="inline-flex shrink-0 h-14 w-14 items-center justify-center rounded-2xl bg-primary/10 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
              </div>
              <div>
                <h3 class="mb-2 text-xl font-semibold text-foreground tracking-tight">Context & Instructions</h3>
                <p class="text-sm text-muted-foreground leading-relaxed">
                  Train your assistant on your exact business knowledge, specific FAQs, and behavioral rules.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* FAQ Section */}
    <section id="faq" class="relative py-24 sm:py-32 bg-secondary/5 z-0">
      <div class="mx-auto max-w-3xl px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl text-balance">
            Frequently Asked Questions
          </h2>
          <p class="mt-4 text-lg leading-relaxed text-muted-foreground">
            Everything you need to know about setting up and using the AI widget platform.
          </p>
        </div>

        <div class="faq-accordion space-y-2">
          {faqItems.map((item, index) => {
            const answerId = `faq-answer-${index + 1}`

            return (
              <div class="faq-item border-b border-border/20 overflow-hidden">
                <button
                  type="button"
                  class="faq-button flex w-full items-center justify-between py-5 text-left font-semibold text-foreground text-lg outline-none transition-colors hover:text-primary"
                  aria-expanded="false"
                  aria-controls={answerId}
                >
                  <span>{item.question}</span>
                  <span class="faq-icon relative flex h-6 w-6 shrink-0 items-center justify-center transition-transform duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="absolute transition-transform duration-300"><path d="M5 12h14"></path><path d="M12 5v14" class="vertical-line transition-transform duration-300"></path></svg>
                  </span>
                </button>
                <div id={answerId} class="faq-content grid transition-all duration-300 grid-rows-[0fr] opacity-0">
                  <div class="overflow-hidden">
                    <p class="pb-6 leading-relaxed text-muted-foreground">
                      {item.answer}
                    </p>
                  </div>
                </div>
              </div>
            )
          })}
        </div>
      </div>
    </section>

    {/* Final CTA Section */}
    <section class="relative py-24 sm:py-32 bg-primary overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary to-primary/80 z-0"></div>
      <div class="relative z-10 mx-auto max-w-4xl px-6 lg:px-8 text-center text-primary-foreground">
        <h2 class="text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl mb-6 text-balance">
          Ready to supercharge your website?
        </h2>
        <p class="mx-auto max-w-2xl text-lg sm:text-xl font-medium text-primary-foreground/90 mb-10 leading-relaxed text-balance">
          Launch a custom AI assistant in minutes, control its knowledge, and manage everything from one intuitive dashboard.
        </p>
        <div class="flex justify-center">
          <a href={siteConfig.dashboardUrl} class="inline-flex h-12 md:h-14 items-center justify-center rounded-full bg-background text-foreground px-8 md:px-10 text-base md:text-lg font-semibold shadow-md hover:scale-105 transition-transform duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-background">
            Get started for free
          </a>
        </div>
      </div>
    </section>

    <script>
      // Smooth collapse/expand via CSS Grid transition
      const buttons = document.querySelectorAll('.faq-button');
      
      buttons.forEach(button => {
        button.addEventListener('click', () => {
          const item = button.closest('.faq-item');
          if (!item) return;

          const content = item.querySelector('.faq-content');
          const verticalLine = item.querySelector('.vertical-line');
          if (!content || !verticalLine) return;

          const isOpen = item.classList.contains('is-open');
          button.setAttribute('aria-expanded', String(!isOpen));

          // Close all logic (Optional, but keeps the layout clean)
          document.querySelectorAll('.faq-item').forEach(otherItem => {
            if (otherItem !== item) {
              otherItem.classList.remove('is-open');
              const otherButton = otherItem.querySelector('.faq-button');
              const otherContent = otherItem.querySelector('.faq-content');
              const otherVerticalLine = otherItem.querySelector('.vertical-line');
              
              if (otherButton) {
                otherButton.setAttribute('aria-expanded', 'false');
              }
              if (otherContent) {
                otherContent.classList.remove('grid-rows-[1fr]', 'opacity-100');
                otherContent.classList.add('grid-rows-[0fr]', 'opacity-0');
              }
              if (otherVerticalLine) {
                otherVerticalLine.classList.remove('rotate-90', 'opacity-0');
              }
            }
          });

          // Toggle current
          if (isOpen) {
            item.classList.remove('is-open');
            content.classList.remove('grid-rows-[1fr]', 'opacity-100');
            content.classList.add('grid-rows-[0fr]', 'opacity-0');
            verticalLine.classList.remove('rotate-90', 'opacity-0');
          } else {
            item.classList.add('is-open');
            content.classList.remove('grid-rows-[0fr]', 'opacity-0');
            content.classList.add('grid-rows-[1fr]', 'opacity-100');
            verticalLine.classList.add('rotate-90', 'opacity-0');
          }
        });
      });

      // Dashboard Preview Parallax Animation
      const preview = document.getElementById('dashboard-preview');
      if (preview) {
        const handleScroll = () => {
          const scrollY = window.scrollY;
          // Calculate progress based on scroll position (0 to 1 over 500px)
          const progress = Math.min(scrollY / 500, 1);
          
          // Animate rotation, translation, scale, and opacity
          const rotateX = 15 - (progress * 15); // from 15deg to 0deg
          const translateY = 40 - (progress * 40); // from 40px to 0px
          const scale = 0.95 + (progress * 0.05); // from 0.95 to 1
          const opacity = 0.5 + (progress * 0.5); // from 0.5 to 1
          
          preview.style.transform = `rotateX(${rotateX}deg) translateY(${translateY}px) scale(${scale})`;
          preview.style.opacity = progress > 0 ? opacity.toString() : '0.5';
        };

        window.addEventListener('scroll', () => {
          requestAnimationFrame(handleScroll);
        }, { passive: true });
        
        // Initial setup on load
        handleScroll();
      }
    </script>
  </main>

  {/* Footer Section */}
  <footer class="relative bg-background pt-20 pb-10 border-t border-border/40">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row justify-between gap-12 lg:gap-8">
        
        {/* Brand & Description */}
        <div class="max-w-sm">
          <a href="/" class="flex items-center gap-2 mb-5 outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-sm w-fit">
            <img src="/logo.png" alt="WidgetAI Logo" width="833" height="217" class="h-8 w-auto object-contain" />
          </a>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Add a custom AI assistant to your website in minutes. Control its knowledge, customize its look, and manage everything from one dashboard.
          </p>
        </div>
        
        {/* Link Groups */}
        <div class="flex flex-wrap gap-12 sm:gap-16 md:gap-24">
          <div>
            <h3 class="font-semibold text-foreground text-sm tracking-wide mb-4">Product</h3>
            <ul class="flex flex-col gap-3 text-sm text-muted-foreground">
              <li><a href="#features" class="hover:text-primary hover:underline underline-offset-4 transition-all outline-none focus-visible:text-primary">Features</a></li>
